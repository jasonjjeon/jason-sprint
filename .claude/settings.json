{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "mcp__redash__*",
      "mcp__context7__*",
      "mcp__filesystem__*",
      "mcp__google-sheets__*",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Sentry__*",
      "mcp__plugin_oh-my-claudecode_t__*",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(py *)",
      "Bash(git *)",
      "Bash(streamlit *)",
      "Bash(playwright *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/check-update.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}